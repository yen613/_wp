<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>李芷妍 | 個人網站</title>
    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); /* 基礎藍色漸層 */
            --header-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%); /* 藍紫色漸層 */
            --accent-color: #ff0844; /* 用於強調的點綴色 (如標籤) */
            --bg-color: #f8f9fa; /* 背景色 */
            --text-color: #333; /* 主文字色 */
            --secondary-text: #6c757d; /* 次要文字色 */
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif, "Microsoft JhengHei";
            line-height: 1.6;
            margin: 0;
            padding: 0;
            background-color: var(--bg-color);
            color: var(--text-color);
        }

        header {
            /* 關鍵：藍紫色漸層背景 */
            background-image: var(--header-gradient);
            color: white;
            padding: 4rem 1rem;
            text-align: center;
            box-shadow: 0 4px 15px rgba(118, 75, 162, 0.3); /* 為漸層添加深度 */
        }

        .container {
            max-width: 800px;
            margin: 2rem auto;
            padding: 0 2rem;
            /* 確保在 GitHub Actions 或 Jekyll 下也能正常顯示 */
        }

        section {
            background: white;
            padding: 2.5rem;
            margin-bottom: 2.5rem;
            border-radius: 12px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            border: 1px solid rgba(0,0,0,0.03); /* 輕微的邊框，讓白色區塊更突出 */
        }

        h1 { margin: 0; font-size: 2.8rem; font-weight: 700; letter-spacing: 1px; }
        h2 { border-left: 6px solid #764ba2; padding-left: 1rem; color: #667eea; font-weight: 600; margin-top: 0; }

        .contact-info {
            display: flex;
            justify-content: center;
            gap: 25px;
            flex-wrap: wrap;
            margin-top: 15px;
        }

        .contact-info span { font-size: 1rem; opacity: 0.9; }
        .contact-info a { color: white; text-decoration: underline; transition: opacity 0.3s; }
        .contact-info a:hover { opacity: 0.7; }

        .skill-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }

        .tag {
            background: rgba(118, 75, 162, 0.1); /* 淺紫色背景 */
            color: #764ba2; /* 深紫色文字 */
            padding: 7px 18px;
            border-radius: 25px;
            font-size: 0.9rem;
            font-weight: 500;
            transition: all 0.3s;
        }
        .tag:hover {
            background-image: var(--header-gradient);
            color: white;
            transform: translateY(-2px);
        }

        ul { padding-left: 1.2rem; }
        ul li { margin-bottom: 0.8rem; color: var(--secondary-text); }
        ul li strong { color: var(--text-color); }

        footer {
            text-align: center;
            padding: 3rem;
            font-size: 0.9rem;
            color: var(--secondary-text);
            border-top: 1px solid rgba(0,0,0,0.05);
        }

        @media (max-width: 600px) {
            h1 { font-size: 2.2rem; }
            header { padding: 3rem 1rem; }
            .container { padding: 0 1.5rem; }
            section { padding: 1.5rem; }
            .contact-info { flex-direction: column; gap: 10px; }
        }
    </style>
</head>
<body>

<header>
