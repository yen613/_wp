<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>編輯 - <%= post.title %> - 簡易網誌</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container">
    <header>
      <h1><a href="/">簡易網誌</a></h1>
      <div style="display:flex;align-items:center;gap:10px">
        <% if (user) { %>
          <span style="font-size:14px;color:#666"><%= user.username %></span>
          <form action="/logout" method="POST" class="inline-form">
            <button type="submit" class="btn btn-danger">登出</button>
          </form>
        <% } %>
        <a href="/post/<%= post.id %>" class="btn">取消</a>
      </div>
    </header>

    <main>
      <h2>編輯文章</h2>
      <form action="/post/<%= post.id %>" method="POST" class="post-form">
        <div>
          <label for="title">標題</label>
          <input type="text" id="title" name="title" value="<%= post.title %>" required>
        </div>
        <div>
          <label for="content">內容</label>
          <textarea id="content" name="content" rows="12" required><%= post.content %></textarea>
        </div>
        <button type="submit" class="btn">儲存變更</button>
      </form>
    </main>
  </div>
</body>
</html>
