<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Threads Blog</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container">
    <header>
      <h1><a href="/">Threads Blog</a></h1>
      <div class="header-right">
        <% if (user) { %>
          <span class="header-user"><%= user.username %></span>
          <a href="/post/new" class="btn btn-sm">寫文章</a>
          <form action="/logout" method="POST" class="inline-form">
            <button type="submit" class="btn btn-sm btn-danger">登出</button>
          </form>
        <% } else { %>
          <a href="/login" class="btn btn-sm btn-outline">登入</a>
          <a href="/register" class="btn btn-sm">註冊</a>
        <% } %>
      </div>
    </header>

    <main>
      <% if (posts.length === 0) { %>
        <p class="empty">
          目前還沒有文章<br>
          <a href="/register">註冊</a> 或 <a href="/login">登入</a> 後開始寫吧
        </p>
      <% } else { %>
        <ul class="post-list">
          <% posts.forEach(post => { %>
            <li>
              <a href="/post/<%= post.id %>" class="post-title"><%= post.title %></a>
              <span class="post-date"><%= new Date(post.created_at).toLocaleString('zh-TW', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </main>
  </div>
</body>
</html>
