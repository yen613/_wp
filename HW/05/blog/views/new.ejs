<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>新文章 - Threads Blog</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container">
    <header>
      <h1><a href="/">Threads Blog</a></h1>
      <div class="header-right">
        <% if (user) { %>
          <span class="header-user"><%= user.username %></span>
          <form action="/logout" method="POST" class="inline-form">
            <button type="submit" class="btn btn-sm btn-danger">登出</button>
          </form>
        <% } %>
        <a href="/" class="btn btn-sm btn-outline">← 返回</a>
      </div>
    </header>

    <main>
      <h2 class="page-title">新文章</h2>
      <form action="/post" method="POST" class="post-form">
        <div>
          <label for="title">標題</label>
          <input type="text" id="title" name="title" placeholder="輸入文章標題..." required>
        </div>
        <div>
          <label for="content">內容</label>
          <textarea id="content" name="content" placeholder="寫點什麼..." required></textarea>
        </div>
        <button type="submit" class="btn">發布</button>
      </form>
    </main>
  </div>
</body>
</html>
