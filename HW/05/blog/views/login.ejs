<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>登入 - Threads Blog</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container">
    <header>
      <h1><a href="/">Threads Blog</a></h1>
      <div class="header-right">
        <a href="/register" class="btn btn-sm btn-outline">註冊</a>
      </div>
    </header>

    <main>
      <h2 class="page-title">登入</h2>
      <form action="/login" method="POST" class="post-form">
        <div>
          <label for="username">使用者名稱</label>
          <input type="text" id="username" name="username" placeholder="輸入使用者名稱" required>
        </div>
        <div>
          <label for="password">密碼</label>
          <input type="password" id="password" name="password" placeholder="輸入密碼" required>
        </div>
        <button type="submit" class="btn">登入</button>
      </form>
      <p class="auth-link">還沒有帳號？<a href="/register">註冊</a></p>
    </main>
  </div>
</body>
</html>
